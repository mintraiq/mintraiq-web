# Public browser configuration for mintraiq-web (Vercel / GitHub Actions build).
# Sync to GitHub Environment: gh variable set -f .env.vars --env STAGING
# Maps to PUBLIC_* in .github/workflows/cd.yml and scripts/build-runtime-env.mjs
# Never put secrets here — all values ship to the browser.

PUBLIC_LOGTO_ENDPOINT=https://ufq3nf.logto.app
PUBLIC_LOGTO_APP_ID=CHANGEME
PUBLIC_LOGTO_REGISTER_URL=
PUBLIC_FINANCE_API_BASE=https://staging-app.mintraiq.com/api
PUBLIC_FINANCE_API_RESOURCE=https://api.finance-ai.suite.com
PUBLIC_SIGN_IN_REDIRECT_URI=
PUBLIC_LEGACY_FLASK_BASE=https://staging-app.mintraiq.com
PUBLIC_FASTAPI_DOCS_URL=https://staging-app.mintraiq.com/api/docs
PUBLIC_FEATURE_RECEIPT_SCANNER=true
PUBLIC_OCR_SCANNER_API_URL=https://staging-scanner.mintraiq.com/ocr/scanner
PUBLIC_OCR_SCANNER_API_RESOURCE=
PUBLIC_STRIPE_PUBLISHABLE_KEY=CHANGEME
PUBLIC_REQUIRE_BILLING_PAYWALL=true
DEPLOY_TO_VERCEL=false
VERCEL_PROJECT_ID=

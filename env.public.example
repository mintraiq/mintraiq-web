# Copy to `env.public` (gitignored) and run: npm run build:env
# Or set the same keys in Vercel → Settings → Environment Variables (PUBLIC_*)
# Redeploy after changing values so `config/runtime-env.js` is regenerated.
#
# Cloudflare Tunnel: set PUBLIC_FINANCE_API_BASE and PUBLIC_LEGACY_FLASK_BASE to your
# tunnel URL (e.g. https://api-xxxxx.trycloudflare.com) while FastAPI runs on localhost.

# --- Logto (browser-safe; never put client_secret here) ---
PUBLIC_LOGTO_ENDPOINT=https://ufq3nf.logto.app
PUBLIC_LOGTO_APP_ID=your-logto-spa-app-id

# Logto Console → this SPA → Settings: under “CORS allowed origins” include every origin users hit (e.g. https://mintraiq.com and https://www.mintraiq.com if both exist). Redirect URIs must match those origins exactly or token/PKCE steps can fail with invalid_grant.

# Optional: Logto hosted registration URL for new-user “Join”. app_id is appended if missing (same as /register?app_id=…).
# PUBLIC_LOGTO_REGISTER_URL=https://ufq3nf.logto.app/register
# PUBLIC_LOGTO_REGISTER_URL=https://ufq3nf.logto.app/register?app_id=your-logto-spa-app-id

# --- FastAPI (Bearer + bootstrap) — include /api if your routes are under /api ---
PUBLIC_FINANCE_API_BASE=http://localhost:5000/api
PUBLIC_FINANCE_API_RESOURCE=https://api.finance-ai.suite.com

# Optional: exact redirect URI registered in Logto (otherwise portal uses /portal/callback.html)
# PUBLIC_SIGN_IN_REDIRECT_URI=https://your-app.vercel.app/portal/callback.html

# --- Legacy Flask cookie UI (legacy/pages) — origin only, no trailing slash ---
PUBLIC_LEGACY_FLASK_BASE=http://127.0.0.1:5000

# Link shown in UI / docs (OpenAPI)
PUBLIC_FASTAPI_DOCS_URL=http://localhost:5000/api/docs

# --- Billing (Stripe — publishable key only; pk_… is browser-safe) ---
# Enables stripe-js redirectToCheckout({ sessionId }); without it the portal
# falls back to the hosted Checkout URL returned by the backend.
PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Billing kill switch (mirror of backend REQUIRE_BILLING_PAYWALL).
# Set to false to hide upgrade CTAs — the UI renders as already-premium.
PUBLIC_REQUIRE_BILLING_PAYWALL=true
